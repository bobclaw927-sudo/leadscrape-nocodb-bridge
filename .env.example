# ─── Required ──────────────────────────────────────────────

# Your NocoDB instance URL (from your browser address bar)
# Example: https://noco-abc123.nocodb.com
NOCODB_URL=https://your-instance.nocodb.com

# NocoDB API token (create one under Account Settings > API Tokens)
NOCODB_API_TOKEN=your_nocodb_api_token_here

# The table to insert leads into
# Options: Home Services Marketers, Lead Generation Agencies – E-commerce & Shopify,
#          Shopify Store Owners, Business Owner & Entrepreneur Influencers, App Partners, Shopify Agencies
NOCODB_TABLE=Home Services Marketers

# Shared secret — LeadScrape sends this in the X-Webhook-Secret header
WEBHOOK_SECRET=choose_a_random_secret_here

# ─── Optional ─────────────────────────────────────────────

# Dedup field: which NocoDB column to check before inserting
# Defaults are: Company_Name (Home Services), Agency Name (Lead Gen),
#               Full_Name (Shopify Owners/Influencers)
# DEDUP_FIELD=Company_Name

# Log level: error, warn, info, debug
# LOG_LEVEL=info
